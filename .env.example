PORT=3001

# Comma-separated websites allowed to call this signing API.
ALLOWED_ORIGINS=https://aliomar0.github.io

# Apple identifiers from the Apple Developer portal
APPLE_PASS_TYPE_IDENTIFIER=pass.com.example.walletstudio
APPLE_TEAM_IDENTIFIER=YOUR_TEAM_ID

# Local certificate paths. Keep these files outside source control.
APPLE_WWDR_CERT_PATH=./certificates/wwdr.pem
APPLE_SIGNER_CERT_PATH=./certificates/signerCert.pem
APPLE_SIGNER_KEY_PATH=./certificates/signerKey.pem
APPLE_SIGNER_KEY_PASSPHRASE=

# For hosted environments, base64 values can be used instead of paths:
# APPLE_WWDR_CERT_BASE64=
# APPLE_SIGNER_CERT_BASE64=
# APPLE_SIGNER_KEY_BASE64=
